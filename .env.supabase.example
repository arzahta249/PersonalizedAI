# Runtime app connection.
# Use the Supabase pooled connection string here for app/server traffic.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Direct database connection for Prisma CLI and one-time schema bootstrap.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Optional: cap pg pool size used by PrismaPg at runtime.
PG_POOL_MAX="5"

# Source database used for exporting legacy data before cutover.
SOURCE_DATABASE_URL="postgresql://postgres:[OLD-PASSWORD]@[OLD-HOST]:5432/[OLD-DB]?sslmode=prefer"

# Optional explicit target override for import scripts.
# Leave empty to fall back to DIRECT_URL, then DATABASE_URL.
TARGET_DATABASE_URL=""

JWT_SECRET="replace-me"
OPENROUTER_API_KEY="replace-me"
ADMIN_REGISTER_CODE="replace-me"
